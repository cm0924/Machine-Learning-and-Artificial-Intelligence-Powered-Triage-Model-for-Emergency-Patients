# 1. Feature Selection
# We only select variables that are available at the time of Triage.
# We DROP 'Diagnosis', 'Disposition', etc., because they happen AFTER triage.
feature_cols = ['Sex', 'Age', 'Arrival mode', 'Injury', 'Chief_complain', 
                'Mental', 'Pain', 'NRS_pain', 'SBP', 'DBP', 'HR', 'RR', 'BT', 'Saturation']
target_col = 'KTAS_expert'

X = df[feature_cols].copy()
y = df[target_col].copy()

# 2. Encode Text Features

import pandas as pd
import numpy as np
from sklearn.impute import SimpleImputer

# 1. Fix the "Dirty" Data Types (Crucial First Step)
# Your inspection showed text like '#BOÅ!' in numeric columns.
# We use 'errors="coerce"' to turn those text errors into NaN (missing values) immediately.

# Fix NRS_pain specifically first to avoid the TypeError you saw earlier
df['NRS_pain'] = pd.to_numeric(df['NRS_pain'], errors='coerce')

# Fix all other vital sign columns
vital_cols = ['Age', 'Patients number per hour', 'SBP', 'DBP', 
              'HR', 'RR', 'BT', 'Saturation', 'Pain', 
              'Mental', 'Arrival mode', 'Injury']

for col in vital_cols:
    df[col] = pd.to_numeric(df[col], errors='coerce')

print("â Data types fixed. All text errors (like '#BOÅ!') are now NaN.")

# 2. Smart Imputation (Filling the Missing Values)

# A. Logic for Pain: 
# If patient said "No" to Pain (Pain=0), their Score (NRS_pain) is 0.
no_pain_mask = df['Pain'] == 0
df.loc[no_pain_mask, 'NRS_pain'] = df.loc[no_pain_mask, 'NRS_pain'].fillna(0)

# Fill remaining missing pain scores with the median
df['NRS_pain'].fillna(df['NRS_pain'].median(), inplace=True)

# B. Logic for Saturation:
# Missing often means "Normal/Not Checked". Fill with median (usually ~98).
df['Saturation'].fillna(df['Saturation'].median(), inplace=True)

# C. Logic for Other Vitals:
# Fill any remaining gaps (like SBP, HR) with the median
imputer = SimpleImputer(strategy='median')
# Note: We combine vital_cols and NRS_pain to ensure everything is covered
cols_to_clean = vital_cols + ['NRS_pain']
df[cols_to_clean] = imputer.fit_transform(df[cols_to_clean])

print("â Imputation Complete. No missing values remain.")


        'params': {
            'classifier__n_estimators': [100, 200],
            'classifier__learning_rate': [0.01, 0.1],
            'classifier__num_leaves': [31, 50]
        }
    },
    {
        'name': 'SVM',
        'model': SVC(probability=True, random_state=42), # Probability=True needed for AUC
        'params': {
            'classifier__C': [0.1, 1, 10],
            'classifier__kernel': ['rbf', 'linear']
        }
    },
    {
        'name': 'KNN',
        'model': KNeighborsClassifier(),
        'params': {
            'classifier__n_neighbors': [3, 5, 7, 9],
            'classifier__weights': ['uniform', 'distance']
        }
    },
    {
        'name': 'Decision Tree',
        'model': DecisionTreeClassifier(random_state=42),
        'params': {
            'classifier__max_depth': [None, 10, 20, 30],
            'classifier__min_samples_split': [2, 5, 10]
        }
    }
]

# 3. Loop Through Models
results = []
best_estimators = {}

print(f"{'Model':<20} | {'Status':<15}")
print("-" * 40)

for config in models_config:
    model_name = config['name']
    print(f"{model_name:<20} | Training...", end='\r')
    
    # Create Pipeline: Scale -> Balance (SMOTE) -> Classify
    # Scaling is crucial for KNN, SVM, LR
    pipeline = ImbPipeline([
        ('scaler', StandardScaler()), 
        ('balancing', SMOTE(random_state=42)),
        ('classifier', config['model'])
    ])
    
    # Grid Search
    grid = GridSearchCV(
        estimator=pipeline,
        param_grid=config['params'],
        cv=cv,
        scoring='accuracy',
        n_jobs=-1
    )
    
    # Train
    grid.fit(X_train, y_train)
    
    # Evaluate on Test Set
    best_model = grid.best_estimator_
    y_pred = best_model.predict(X_test)
    y_prob = best_model.predict_proba(X_test)
    
    # Metrics
    acc = accuracy_score(y_test, y_pred)
    auc = roc_auc_score(y_test, y_prob, multi_class='ovr')
    
    # Store
    results.append({
        'Model': model_name,
        'Test Accuracy': acc,
        'Test AUC': auc,
        'Best Params': grid.best_params_
    })
    
    best_estimators[model_name] = best_model
    print(f"{model_name:<20} | Done (Acc: {acc:.4f})")

# 4. Display Comparison
results_df = pd.DataFrame(results).sort_values(by='Test Accuracy', ascending=False)
print("\n--- Final Model Comparison ---")
print(results_df[['Model', 'Test Accuracy', 'Test AUC']])


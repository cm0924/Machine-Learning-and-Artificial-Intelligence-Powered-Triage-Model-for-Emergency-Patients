    'abd pain': 'abdominal pain',
    'abd. pain': 'abdominal pain',
    'abdomianl pain': 'abdominal pain',
    'rt ': 'right ',
    'lt ': 'left ',
    'sob': 'dyspnea',
    'shortness of breath': 'dyspnea',
    'mva': 'traffic accident',
    'ta': 'traffic accident',
    'diarrhea': 'diarrhoea'
}
df['Chief_complain'] = df['Chief_complain'].replace(replacements, regex=True)

# 5. Group Rare Complaints

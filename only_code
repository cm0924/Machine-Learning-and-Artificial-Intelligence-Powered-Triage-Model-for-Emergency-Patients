except AttributeError:
    final_model = winner_model
    X_test_scaled = X_test

# 2. Calculate SHAP Values
print("Calculating SHAP values...")
explainer = shap.TreeExplainer(final_model)
shap_values = explainer.shap_values(X_test_scaled)

# 3. ROBUST EXTRACTION LOGIC
# We need to find where the "Critical" class (Level 1 / Index 0) is hiding
if isinstance(shap_values, list):
    # Format: List of [N_samples, N_features]
    print("Detected SHAP format: List")
    shap_data_summary = shap_values[0] # Class 0
elif isinstance(shap_values, np.ndarray) and len(shap_values.shape) == 3:
    # Format: [N_samples, N_features, N_classes]
    print("Detected SHAP format: 3D Array")
    shap_data_summary = shap_values[:, :, 0] # All samples, All features, Class 0
else:
    # Format: [N_samples, N_features] (Binary/Regression)
    print("Detected SHAP format: 2D Array")
    shap_data_summary = shap_values

# 4. Summary Plots
plt.figure(figsize=(10, 6))
plt.title("Feature Importance (Global - Level 1 Risk)")
shap.summary_plot(shap_data_summary, X_test, plot_type="bar", show=False)
plt.show()

plt.figure(figsize=(10, 6))
plt.title("Detailed Feature Impact (Beeswarm)")
shap.summary_plot(shap_data_summary, X_test, show=False)
plt.show()

# 5. Single Patient Waterfall Plot
patient_idx = 0 
predicted_class_idx = y_pred_win[patient_idx]

print(f"\nExplaining Patient #{patient_idx} (Predicted Level {predicted_class_idx + 1})")

# --- SAFE SLICING FOR SINGLE PATIENT ---
if isinstance(shap_values, list):
    # List case
    shap_patient_1d = shap_values[predicted_class_idx][patient_idx]
    base_val_raw = explainer.expected_value[predicted_class_idx]
elif len(np.array(shap_values).shape) == 3:
    # 3D Array case: [Sample, Feature, Class]
    shap_patient_1d = shap_values[patient_idx, :, predicted_class_idx]
    
    # Handle base value extraction for 3D case
    if isinstance(explainer.expected_value, np.ndarray) and len(explainer.expected_value) > 1:
         base_val_raw = explainer.expected_value[predicted_class_idx]
    else:
         base_val_raw = explainer.expected_value
else:
    # 2D Array case
    shap_patient_1d = shap_values[patient_idx]
    base_val_raw = explainer.expected_value

# Helper to ensure Base Value is a clean float
def clean_float(val):
    if hasattr(val, 'item'): return val.item()
    if hasattr(val, '__iter__'): return clean_float(val[0])
    return float(val)

base_value = clean_float(base_val_raw)

print(f"SHAP Shape: {shap_patient_1d.shape} (Should be (14,))")
print(f"Base Value: {base_value}")

# Plot
plt.figure(figsize=(10, 6))
explanation = shap.Explanation(
    values=shap_patient_1d,
    base_values=base_value,
    data=X_test.iloc[patient_idx, :].values,
    feature_names=X_test.columns
)
plt.title(f"Why Level {predicted_class_idx+1}?")

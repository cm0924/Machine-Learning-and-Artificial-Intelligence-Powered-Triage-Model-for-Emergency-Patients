# 1. Visualize Outliers using Boxplots
# This helps us differentiate between "Sick Patients" and "Impossible Data"
vitals_to_check = ['SBP', 'DBP', 'HR', 'RR', 'BT', 'Saturation']

plt.figure(figsize=(15, 10))

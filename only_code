    plt.title(f'Boxplot of {col}')
    plt.grid(True, linestyle='--', alpha=0.6)

plt.tight_layout()
plt.show()

# 2. Define Physiological Limits (Domain Knowledge)
# We only remove/cap values that are biologically IMPOSSIBLE.
# We DO NOT remove values just because they are high (e.g., HR 180 is real).

print("--- Checking for Impossible Values ---")

# Rule A: Oxygen Saturation cannot be > 100%
# Error found: SpO2 of 500 or 120 is impossible.
invalid_sat = df[df['Saturation'] > 100]
print(f"Saturation > 100%: {len(invalid_sat)} cases found. Fixing...")
# Fix: Cap at 100
df['Saturation'] = df['Saturation'].clip(upper=100)

# Rule B: Body Temp (BT) 
# Error found: BT > 45C (likely missed decimal, e.g., 365 -> 36.5) or < 25C
invalid_bt = df[(df['BT'] > 45) | (df['BT'] < 25)]
print(f"Body Temp Errors (>45C or <25C): {len(invalid_bt)} cases found.")
if len(invalid_bt) > 0:
    print(invalid_bt['BT'].head())
    # Fix: If > 100, divide by 10 (assuming missing decimal)
    df.loc[df['BT'] > 100, 'BT'] = df.loc[df['BT'] > 100, 'BT'] / 10
    # Drop remaining crazy values if any
    df = df[(df['BT'] <= 45) & (df['BT'] >= 25)]

# Rule C: Heart Rate (HR) and BP
# Ranges: HR (0-300), SBP (0-300). Anything else is likely an error.
df = df[(df['HR'] > 0) & (df['HR'] < 300)]
df = df[(df['SBP'] > 0) & (df['SBP'] < 300)]
df = df[(df['DBP'] > 0) & (df['DBP'] < 200)]

print("â Impossible outliers removed/corrected.")
print(f"New Dataset Shape: {df.shape}")

# 3. Re-Visualize to Confirm
plt.figure(figsize=(15, 10))
for i, col in enumerate(vitals_to_check, 1):
    plt.subplot(2, 3, i)
    sns.boxplot(y=df[col], color='lightgreen')
    plt.title(f'Cleaned {col}')
    plt.grid(True, linestyle='--', alpha=0.6)

plt.tight_layout()
plt.show()

# ---------------------------------------------------------
# Step 2.8: Text Cleaning (Fixed to keep 'Burn')
# ---------------------------------------------------------
print(f"Unique Complaints BEFORE cleaning: {df['Chief_complain'].nunique()}")

# 1. Lowercase and Strip
df['Chief_complain'] = df['Chief_complain'].astype(str).str.lower().str.strip()

# 2. Remove Garbage ('??')
def clean_garbage(text):
    if '?' in text: return 'other'
    return text
df['Chief_complain'] = df['Chief_complain'].apply(clean_garbage)

# 3. INTELLIGENT GROUPING (The Fix)
# We group variations so they survive the "Rare" filter
# Example: "burn, arm" and "chemical burn" -> BOTH become "burn"
df.loc[df['Chief_complain'].str.contains('burn', na=False), 'Chief_complain'] = 'burn'
df.loc[df['Chief_complain'].str.contains('fracture', na=False), 'Chief_complain'] = 'fracture'
df.loc[df['Chief_complain'].str.contains('trauma', na=False), 'Chief_complain'] = 'trauma'
df.loc[df['Chief_complain'].str.contains('lacera', na=False), 'Chief_complain'] = 'laceration'

# 4. Manual Mapping
